{
  "name": "hq",
  "version": "0.0.0",
  "private": true,
  "description": "HeadQuarter — a local command center for autonomous Claude Code teams",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:bin": "bun build packages/cli/src/bin.ts --compile --outfile dist/hq",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test --timeout 30000 --max-concurrency 1 packages/*/test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
